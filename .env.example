# Salin file ini ke .env.local dan isi nilainya
# Atau set langsung di Vercel Dashboard → Settings → Environment Variables

# Info repo GitHub
NEXT_PUBLIC_REPO_OWNER=nama-owner-atau-org
NEXT_PUBLIC_REPO_NAME=nama-repo

# Dari GitHub OAuth App (Settings → Developer settings → OAuth Apps)
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=

# String acak minimal 32 karakter (bisa generate di: https://generate-secret.vercel.app/32)
KEYSTATIC_SECRET=
